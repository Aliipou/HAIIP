# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./haiip_dev.db

# Production (PostgreSQL) — uncomment and fill
# DATABASE_URL=postgresql+asyncpg://haiip:STRONG_PASSWORD@db:5432/haiip

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── LLM / RAG ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-REPLACE_WITH_REAL_KEY
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── OPC UA ───────────────────────────────────────────────────────────────────
OPCUA_ENDPOINT=opc.tcp://localhost:4840/freeopcua/server/
OPCUA_NAMESPACE=2

# ── MQTT ─────────────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_TOPIC_PREFIX=haiip/sensors

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# ── Multi-tenancy ─────────────────────────────────────────────────────────────
DEFAULT_TENANT_ID=default
MAX_TENANTS=50

# ── ML ───────────────────────────────────────────────────────────────────────
MODEL_ARTIFACTS_PATH=./artifacts/models
ANOMALY_CONTAMINATION=0.05
DRIFT_THRESHOLD=0.05
CONFIDENCE_MIN=0.6
