{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "piechart", "name": "Pie chart", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "HAIIP Economic Decisions — ELM actions, net benefit, human overrides, ROI",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 10000 }
            ]
          },
          "unit": "currencyEUR"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "background" },
      "title": "Total Net Benefit Avoided (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(haiip_economic_net_benefit_eur_total[24h]))",
          "legendFormat": "EUR saved"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "title": "REPAIR_NOW Decisions (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(haiip_economic_decisions_total{action=\"REPAIR_NOW\"}[24h]))",
          "legendFormat": "REPAIR_NOW"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "title": "Human Overrides (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(haiip_human_overrides_total[24h]))",
          "legendFormat": "overrides"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "green", "value": 0.15 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Human Intervention Rate (HIR)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "haiip_human_intervention_rate",
          "legendFormat": "HIR"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "id": 5,
      "options": { "pieType": "donut", "displayLabels": ["name", "percent"] },
      "title": "Decision Distribution",
      "type": "piechart",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(haiip_economic_decisions_total[24h])) by (action)",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "currencyEUR", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "id": 6,
      "title": "Cumulative Net Benefit Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(increase(haiip_economic_net_benefit_eur_total[5m]))",
          "legendFormat": "net benefit EUR"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 7,
      "title": "Economic Decision Rate by Action",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(haiip_economic_decisions_total[5m])) by (action)",
          "legendFormat": "{{action}}"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["haiip", "economic", "decisions"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HAIIP — Economic Decisions",
  "uid": "haiip-economic-decisions",
  "version": 1
}
