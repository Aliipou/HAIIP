{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "HAIIP Drift Detection — model drift, anomaly rates, retraining triggers",
  "editable": false,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.2 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "PSI (Population Stability Index)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "haiip_drift_psi",
          "legendFormat": "PSI"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Drift Alerts Active",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "haiip_drift_alerts_total",
          "legendFormat": "alerts"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "title": "Anomaly Rate (last 5m)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(haiip_predictions_total{label=\"anomaly\"}[5m])) / sum(rate(haiip_predictions_total[5m]))",
          "legendFormat": "anomaly %"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["sum"] }, "colorMode": "value" },
      "title": "Retraining Triggers (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "increase(haiip_retraining_triggered_total[24h])",
          "legendFormat": "triggers"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "id": 5,
      "title": "Anomaly Score Distribution Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(haiip_anomaly_score_bucket[5m])) by (le))",
          "legendFormat": "P50 score"
        },
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum(rate(haiip_anomaly_score_bucket[5m])) by (le))",
          "legendFormat": "P95 score"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "id": 6,
      "title": "KS Test p-values by Feature",
      "type": "timeseries",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "haiip_drift_ks_pvalue",
          "legendFormat": "{{feature}}"
        }
      ]
    }
  ],
  "refresh": "60s",
  "schemaVersion": 38,
  "tags": ["haiip", "drift", "ml"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HAIIP — Drift Detection",
  "uid": "haiip-drift-detection",
  "version": 1
}
